[nix]
channel = "stable-23_11"

[deployment]
run = "./main.ts"
deploymentTarget = "cloudrun"

[languages]
[languages.deno]
pattern = "**/*.{ts,js,tsx,jsx,json,jsonc,md,mdx}"
[languages.deno.languageServer]
start = ["direnv", "exec", ".", "deno", "lsp"]
[languages.deno.languageServer.initializationOptions]
enable = true
lint = true
unstable = true
config = "./deno.jsonc"
suggest.imports.autoDiscover = false
enablePaths = [
  "./packages",
  "./infra",
  "./experimental",
  "./docs",
  "./content",
  "./lib",
]
maxTsServerMemory = 16000

# [languages.relay]
# pattern = "**/*.{tsx,jsx}"
# [languages.relay.languageServer]
# start = [
