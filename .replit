compile = "direnv exec . bff build"
run = "direnv exec . ./main.ts"

[env]
FLAG_DIRENV = "1"
REPLIT_PID1_FLAG_DIRENV = "1"
DENO_DIR = "/home/runner/${REPL_SLUG}/.deno"
